# --- required ---
# LiveKit server (LiveKit Cloud project URL or self-hosted)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxx
# the shared secret from your StandIn identity (pairing issues it); must match exactly
WORKER_SHARED_SECRET=change-me

# --- LiveKit agent dispatch ---
# EXPLICIT dispatch (LiveKit's recommended model). Set this to the exact agent_name
# your worker registers with (the example agents use "standin-voice-agent" /
# "standin-avatar-agent"; see examples/agents).
# WARNING: a worker that registers a name is ONLY reachable by explicit dispatch. If
# your worker sets agent_name but you leave this unset, the bridge falls back to
# automatic dispatch and your agent will NEVER join the call - the single most common
# setup mistake. Leave this unset ONLY if your worker also registers with no name
# (automatic dispatch, joins every room; prototype-only).
LIVEKIT_AGENT_NAME=standin-voice-agent
# room per call: `${prefix}${callId}`
LIVEKIT_ROOM_PREFIX=msteams-
# delete the room at teardown so the agent job ends immediately (billing hygiene)
LIVEKIT_DELETE_ROOM_ON_END=true

# --- optional ---
PORT=8080
BIND=0.0.0.0
# bridge-side call governor: hard cap in minutes (fractional ok); 0 = disabled
MAX_CALL_MINUTES=0
#GOODBYE_TEXT=I'm sorry, we've reached the time limit for this call. Thank you for calling, goodbye!
GOODBYE_GRACE_MS=8000
# HMAC replay window in ms (worker documents ±60s)
HMAC_FRESHNESS_MS=60000
# DoS guards (0 = built-in defaults: 64 / no per-IP throttle / 10000 / 90000)
MAX_CONNECTIONS=0
MAX_CONNECTIONS_PER_IP=0
PRE_START_TIMEOUT_MS=0
WORKER_IDLE_TIMEOUT_MS=0
# per-IP cap behind a proxy you control: trust the first X-Forwarded-For hop
TRUST_PROXY_XFF=false
LOG_LEVEL=info
